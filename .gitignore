```yaml
# Configuration file for Codemagic CI/CD
# No specific gitignore rules needed for codemagic.yaml itself
# as it's a configuration file that should be version controlled

# However, if there are typical build artifacts from Codemagic,
# these might be relevant:

# Build outputs
build/
dist/
release/

# Dependencies
node_modules/
vendor/

# Logs
*.log

# Environment
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Python specific (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Java specific (if applicable)
*.class
*.jar
*.war
target/
.gradle/

# Temporary files
*.tmp
*.temp
*~

# Coverage reports
coverage/
htmlcov/
.coverage

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
```